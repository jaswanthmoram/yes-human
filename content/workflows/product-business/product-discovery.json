{
  "id": "product-business.product-discovery",
  "version": "1.0.0",
  "status": "active",
  "summary": "Run a product discovery cycle from problem identification through validated solution concepts.",
  "task_family": "discovery",
  "triggers": [
    "run product discovery",
    "discover what to build next",
    "product discovery cycle"
  ],
  "aliases": [
    "discovery process",
    "product exploration",
    "opportunity discovery"
  ],
  "negative_keywords": [
    "implement code now",
    "deploy to production",
    "security audit"
  ],
  "inputs": [
    {
      "name": "problem_space",
      "required": true
    },
    {
      "name": "user_segment",
      "required": true
    },
    {
      "name": "business_context",
      "required": false
    }
  ],
  "outputs": [
    {
      "name": "validated_problem_statement"
    },
    {
      "name": "solution_concepts"
    },
    {
      "name": "discovery_report"
    }
  ],
  "primary_agent": "product-business.product-manager",
  "route": {
    "domain_master": "product-business.master",
    "primary": "product-business.product-manager",
    "participants": [
      "product-business.user-researcher",
      "product-business.product-analyst"
    ],
    "parallel": false,
    "max_parallel_agents": 2
  },
  "budget": {
    "band": "standard",
    "max_context_tokens": 5000,
    "max_tool_calls": 15
  },
  "gates": [
    "pre-route",
    "pre-tool",
    "on-task-complete"
  ],
  "steps": [
    {
      "id": "define-problem",
      "summary": "Frame the problem space with user evidence and business context."
    },
    {
      "id": "research-users",
      "summary": "Conduct user research to validate problem and uncover needs."
    },
    {
      "id": "generate-concepts",
      "summary": "Generate and evaluate solution concepts against user needs and feasibility."
    },
    {
      "id": "validate-and-report",
      "summary": "Validate top concepts and produce discovery report with recommendations."
    }
  ],
  "tools": [
    "filesystem.read",
    "doc_parser",
    "research_template"
  ],
  "verification": [
    "problem_validated_with_user_evidence",
    "solution_concepts_evaluated",
    "recommendations_actionable"
  ],
  "success_criteria": [
    "Problem is validated with real user data, not assumptions.",
    "Solution concepts are evaluated against user needs and feasibility.",
    "Discovery report provides clear next steps for product decisions."
  ],
  "rollback": {
    "mode": "no_write",
    "summary": "Discovery workflow does not modify product scope by itself."
  },
  "source_references": [
    "ref.workflow.product-business.product-discovery.2026-05-31"
  ],
  "promotion": {
    "can_learn": true,
    "quality_gate": "staging",
    "min_successes_before_update": 2
  }
}
