{
  "id": "product-business.product-launch",
  "version": "1.0.0",
  "status": "active",
  "summary": "Coordinate a product launch across all functional areas with readiness checks and post-launch monitoring.",
  "task_family": "launch",
  "triggers": ["plan product launch", "coordinate the launch", "launch readiness process"],
  "aliases": ["launch coordination", "go live process", "launch workflow"],
  "negative_keywords": ["implement code now", "security audit", "hr onboarding"],
  "inputs": [
    {
      "name": "launch_scope",
      "required": true
    },
    {
      "name": "target_audience",
      "required": true
    },
    {
      "name": "launch_timeline",
      "required": false
    }
  ],
  "outputs": [
    {
      "name": "launch_plan"
    },
    {
      "name": "readiness_report"
    },
    {
      "name": "post_launch_review"
    }
  ],
  "primary_agent": "product-business.product-launcher",
  "route": {
    "domain_master": "product-business.master",
    "agents": ["product-business.product-launcher"],
    "parallel": false,
    "max_parallel_agents": 2,
    "primary": "product-business.product-launcher",
    "participants": ["product-business.product-marketer", "product-business.product-ops"]
  },
  "budget": {
    "band": "standard",
    "max_context_tokens": 5000,
    "max_tool_calls": 15
  },
  "gates": ["pre-route", "pre-tool", "on-task-complete"],
  "steps": [
    {
      "id": "plan-launch",
      "summary": "Define launch scope, audience, timeline, and cross-functional responsibilities."
    },
    {
      "id": "prepare-assets",
      "summary": "Coordinate marketing, docs, support, and engineering readiness."
    },
    {
      "id": "readiness-review",
      "summary": "Conduct go/no-go readiness review with all functional areas."
    },
    {
      "id": "execute-and-monitor",
      "summary": "Execute launch and monitor success metrics with rollback plan ready."
    }
  ],
  "tools": ["filesystem.read", "launch_checklist", "monitoring_dashboard"],
  "verification": ["all_functional_areas_covered", "readiness_criteria_met", "monitoring_in_place"],
  "success_criteria": [
    "All functional areas have completed readiness checklists.",
    "Go/no-go criteria are met before launch.",
    "Post-launch monitoring is in place with defined metrics."
  ],
  "rollback": {
    "mode": "rollback_plan",
    "summary": "Launch includes rollback plan for technical and communication contingencies."
  },
  "source_references": ["ref.workflow.product-business.product-launch.2026-05-31"],
  "promotion": {
    "can_learn": true,
    "quality_gate": "staging",
    "min_successes_before_update": 2
  }
}
