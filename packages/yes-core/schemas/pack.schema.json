{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PackDefinition",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "workflow.schema.json"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "description"
        ]
      }
    }
  },
  "required": [
    "name",
    "description",
    "workflows",
    "skills"
  ]
}
