{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Yes-human Lifecycle State Machine Schema",
  "type": "object",
  "required": ["id", "version", "initial", "states", "transitions"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "initial": { "type": "string" },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["normal", "gate", "terminal"] },
          "gate": { "type": "string", "enum": ["allow", "ask", "deny"] },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "on", "to"],
        "properties": {
          "from": { "type": "string" },
          "on": { "type": "string" },
          "to": { "type": "string" },
          "guard": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
