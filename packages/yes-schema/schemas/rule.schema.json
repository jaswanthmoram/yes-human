{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Yes-human Rule Schema",
  "type": "object",
  "required": ["id", "version", "rules"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "applies_to": { "type": "array", "items": { "type": "string" } },
    "default": { "type": "string" },
    "tiebreakers": { "type": "object" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["when", "then"],
        "properties": {
          "when": { "type": "object" },
          "then": { "type": "string" },
          "reason": { "type": "string" },
          "connector": { "type": "string" },
          "route": { "type": "string" },
          "workflow": { "type": "string" },
          "priority": { "type": "number" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
