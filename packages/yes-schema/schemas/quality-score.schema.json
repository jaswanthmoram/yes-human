{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Yes-human Quality Score Schema",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "signals", "total", "computed_at"],
  "properties": {
    "artifact_id": { "type": "string" },
    "artifact_type": { "type": "string", "enum": ["agent", "skill", "workflow", "route", "command"] },
    "signals": {
      "type": "object",
      "required": ["quality", "health", "drift", "usage"],
      "properties": {
        "quality": { "type": "number", "minimum": 0, "maximum": 100 },
        "health": { "type": "number", "minimum": 0, "maximum": 100 },
        "drift": { "type": "number", "minimum": 0, "maximum": 100 },
        "usage": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "total": { "type": "number", "minimum": 0, "maximum": 100 },
    "computed_at": { "type": "string", "format": "date-time" },
    "recommendation": { "type": "string", "enum": ["promote", "keep", "rewrite", "reject"] }
  },
  "additionalProperties": false
}
