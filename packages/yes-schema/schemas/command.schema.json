{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Yes-human Command Schema",
  "type": "object",
  "required": ["id", "name", "summary", "maps_to"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "summary": { "type": "string" },
    "maps_to": {
      "type": "object",
      "required": ["kind", "ref"],
      "properties": {
        "kind": { "type": "string", "enum": ["skill", "workflow", "agent", "cli"] },
        "ref": { "type": "string" }
      },
      "additionalProperties": false
    },
    "args": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "required": { "type": "boolean" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "host_support": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "additionalProperties": false
}
