{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Yes-human Policy Schema",
  "type": "object",
  "required": ["id", "version", "default", "rules"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "default": { "type": "string", "enum": ["allow", "ask", "deny"] },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["match", "decision", "reason"],
        "properties": {
          "match": { "type": "object" },
          "decision": { "type": "string", "enum": ["allow", "ask", "deny", "redact"] },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
