{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Yes-human Provenance Schema",
  "type": "object",
  "required": ["id", "item_id", "kind", "source", "created_at", "confidence", "author"],
  "properties": {
    "id": { "type": "string" },
    "item_id": { "type": "string" },
    "kind": { "type": "string" },
    "source": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "author": { "type": "string" }
  },
  "additionalProperties": true
}
