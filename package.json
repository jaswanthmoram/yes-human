{
  "name": "yes-human",
  "version": "2.3.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "yes": "node packages/yes-cli/dist/index.js",
    "build": "tsc --build",
    "typecheck": "tsc --build --noEmit",
    "test": "NODE_ENV=test node --test 'tests/**/*.test.js'",
    "lint": "eslint .",
    "bench": "node packages/yes-cli/dist/index.js bench",
    "validate": "npm run typecheck && npm run build && npm run test && npm run bench",
    "eval:cost": "node packages/yes-schema/eval-cost.js",
    "phase9:gate": "node packages/yes-cli/index.js evaluator gate",
    "phase9:trainer": "node packages/yes-cli/index.js trainer report",
    "doctor": "node packages/yes-cli/index.js doctor",
    "build:hosts": "node packages/yes-cli/index.js build all",
    "audit:dossiers": "node packages/yes-schema/audit-dossiers.js",
    "audit:dossiers:strict": "node packages/yes-schema/audit-dossiers.js --strict",
    "phase9:acceptance": "npm run phase9:gate && npm run phase9:trainer",
    "audit:promotion": "node packages/yes-schema/audit-promotion.js --strict",
    "audit:route-dedup": "node scripts/dedup-hot-routes.mjs",
    "detect:skill-stubs": "node scripts/detect-skill-stubs.mjs",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:coverage": "NODE_ENV=test c8 --reporter=text --reporter=lcov node --test 'tests/**/*.test.js'",
    "bench:routing": "node benchmarks/routing.bench.js",
    "bench:assert": "node benchmarks/assert-baseline.js",
    "bench:build": "node benchmarks/build.bench.js",
    "promote:check": "node scripts/promote-all-agents.mjs --check",
    "promote:apply": "node scripts/promote-all-agents.mjs --apply",
    "uplift:dossiers": "node scripts/uplift-dossiers.mjs --force",
    "sync:dossiers": "node scripts/sync-dossier-promotion-decision.mjs",
    "high-stakes:dossiers": "node scripts/high-stakes-authoritative.mjs",
    "absorb:copy-skills": "node scripts/absorb-skills-from-staging.mjs",
    "promote:skills:check": "node scripts/promote-all-skills.mjs --check",
    "promote:skills:apply": "node scripts/promote-all-skills.mjs --apply --only-staging",
    "audit:skills": "node packages/yes-schema/audit-skills.js --strict",
    "report:health": "node scripts/agent-health-report.mjs",
    "validate:drift": "node packages/yes-schema/validate-drift.js",
    "report:adapter-parity": "node packages/yes-schema/generate-adapter-parity.js"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "c8": "11.0.0",
    "eslint": "10.4.1",
    "prettier": "3.8.3"
  }
}
