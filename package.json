{
  "name": "yes-human",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "yes": "node packages/yes-cli/index.js",
    "validate": "node packages/yes-schema/validate.js",
    "eval:cost": "node packages/yes-schema/eval-cost.js",
    "report:phase8": "node packages/yes-schema/generate-phase8-acceptance.js",
    "doctor": "node packages/yes-cli/index.js doctor",
    "test": "node --test 'tests/**/*.test.js'",
    "build:hosts": "node packages/yes-cli/index.js build all",
    "audit:dossiers": "node packages/yes-schema/audit-dossiers.js",
    "audit:dossiers:strict": "node packages/yes-schema/audit-dossiers.js --strict",
    "research:gaps": "node packages/yes-schema/generate-research-gaps.js"
  }
}
