{
  "id": "network.policy",
  "version": "1.0.0",
  "description": "Network access control policy",
  "applies_to": ["tool.execute", "network.request"],
  "default": "allow",
  "rules": [
    {
      "match": { "url": { "$matches": "^http://" } },
      "decision": "deny",
      "reason": "HTTP URLs are blocked, use HTTPS"
    },
    {
      "match": { "url": { "$matches": "^https://api\\.github\\.com" } },
      "decision": "allow",
      "reason": "GitHub API is trusted"
    },
    {
      "match": { "url": { "$matches": "^https://registry\\.npmjs\\.org" } },
      "decision": "allow",
      "reason": "NPM registry is trusted"
    },
    {
      "match": { "url": { "$matches": "^https://pypi\\.org" } },
      "decision": "allow",
      "reason": "PyPI is trusted"
    },
    {
      "match": { "url": { "$matches": "localhost|127\\.0\\.0\\.1" } },
      "decision": "allow",
      "reason": "Localhost is allowed"
    }
  ]
}
