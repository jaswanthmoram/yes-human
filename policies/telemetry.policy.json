{
  "id": "telemetry.policy",
  "version": "1.0.0",
  "description": "Telemetry and logging policy",
  "applies_to": ["log", "telemetry", "trace"],
  "default": "allow",
  "rules": [
    {
      "match": { "level": "debug" },
      "decision": "allow",
      "reason": "Debug logging allowed"
    },
    {
      "match": { "level": "info" },
      "decision": "allow",
      "reason": "Info logging allowed"
    },
    {
      "match": { "level": "warn" },
      "decision": "allow",
      "reason": "Warning logging allowed"
    },
    {
      "match": { "level": "error" },
      "decision": "allow",
      "reason": "Error logging allowed"
    },
    {
      "match": { "contains": { "$matches": "password|secret|token|api_key" } },
      "decision": "redact",
      "reason": "Sensitive data must be redacted"
    }
  ]
}
