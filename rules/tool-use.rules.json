{
  "id": "tool-use.rules",
  "version": "1.0.0",
  "description": "Tool permission logic and agent authorization",
  "applies_to": ["tool.execute"],
  "default": "allow",
  "rules": [
    {
      "when": {
        "tool": "bash",
        "agent": { "$not_in": ["engineering.master", "platform.master", "meta-system.master"] }
      },
      "then": "ask",
      "reason": "Agent not authorized for bash execution"
    },
    {
      "when": {
        "tool": "file.write",
        "path": { "$starts_with": "content/agents/" }
      },
      "then": "allow",
      "reason": "Agent file modification allowed"
    },
    {
      "when": {
        "tool": "file.write",
        "path": { "$starts_with": "registry/" }
      },
      "then": "ask",
      "reason": "Registry modification requires confirmation"
    },
    {
      "when": {
        "tool": "file.write",
        "path": { "$starts_with": "graph/" }
      },
      "then": "ask",
      "reason": "Graph modification requires confirmation"
    },
    {
      "when": {
        "tool": "network",
        "url": { "$matches": "^http://" }
      },
      "then": "deny",
      "reason": "HTTP (non-HTTPS) network requests blocked"
    }
  ]
}
